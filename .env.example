# 이 파일을 .env.local 로 복사한 뒤 실제 값을 채워넣을 것 (실제 값은 여기에 커밋 금지)
# Supabase 대시보드 > Project Settings > API Keys 에서 복사

# URL 은 https://xxxx.supabase.co 형태 그대로 (뒤에 /rest/v1/ 등 경로를 붙이지 말 것)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
# sb_publishable_ 로 시작하는 Publishable key (구 anon key 후속)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# 공개 청첩장 절대 URL 생성 및 OG 태그에 사용
# 배포 시 https://your-domain.com 으로 교체
NEXT_PUBLIC_SITE_URL=http://localhost:3000
